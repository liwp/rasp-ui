{
  "name": "rasp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "leaflet": "^1.9.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "react-leaflet": "^5.0.0",
    "use-query-params": "^2.2.2"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "TZ=Europe/London vitest run",
    "test:watch": "TZ=Europe/London vitest",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "typecheck": "tsc --noEmit",
    "deploy": "bun run build && surge dist https://rasp.surge.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/leaflet": "^1.9.18",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "surge": "^0.27.4",
    "typescript": "^5.8.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
