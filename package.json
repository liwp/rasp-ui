    "test": "react-scripts test --env=jsdom"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "surge": "^0.27.4"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not op_mini all"
