{
  "name": "rasp",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "leaflet": "^1.9.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "react-leaflet": "^5.0.0",
    "react-scripts": "5.0.1",
    "use-query-params": "^2.2.2"
  },
  "scripts": {
    "build": "react-scripts build",
    "deploy": "npm run build && surge build https://rasp.surge.sh",
